# ── Apify (Lead Scraping) ──────────────────────────────────────
# Sign up at https://apify.com — free tier gives ~$5 credit/month
APIFY_API_TOKEN=your_apify_token_here

# ── Gmail (Email Sending) ──────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable Gmail API
# 3. OAuth 2.0 → Desktop app → Download credentials.json
# 4. Run: python tools/gmail_tools.py --auth
GMAIL_CREDENTIALS_FILE=gmail_credentials.json
GMAIL_TOKEN_FILE=gmail_token.json
SENDER_EMAIL=your@gmail.com
SENDER_NAME=Your Name

# ── Calendly (Meeting Booking) ─────────────────────────────────
# Get API key at https://calendly.com/integrations/api_webhooks
CALENDLY_API_KEY=your_calendly_api_key
CALENDLY_MEETING_LINK=https://calendly.com/yourname/15min

# ── Anthropic Claude (AI Personalization) ─────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── CVS Company Info ───────────────────────────────────────────
COMPANY_PORTFOLIO_URL=https://yoursite.com/portfolio
COMPANY_DEMO_URL=https://yoursite.com/demo
COMPANY_WEBSITE=https://yoursite.com
